  .eyebrow{
    display:inline-flex;align-items:center;gap:8px;
    color:var(--ouro-claro);font-weight:700;font-size:.78rem;
    letter-spacing:.16em;text-transform:uppercase;margin-bottom:18px;
    border:1px solid var(--linha);padding:6px 13px;border-radius:100px;

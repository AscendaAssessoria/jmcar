  h1 em{color:var(--ouro);font-style:normal}
  .sub{color:var(--cinza);font-size:1.06rem;margin:20px 0 30px;max-width:33ch}
  .hero-ctas{display:flex;flex-wrap:wrap;gap:13px}
  .btn{
    display:inline-flex;align-items:center;gap:9px;text-decoration:none;
    font-weight:800;padding:15px 24px;border-radius:10px;font-size:1rem;
